<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimaryDark"
    android:orientation="vertical"
    tools:context=".ProductivityAdminActivity">

    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:srcCompat="@drawable/productivityadmin" />

    <Spinner
        android:id="@+id/spinnerUserAdmin"
        android:layout_width="191dp"
        android:layout_height="30dp"
        android:layout_marginLeft="120dp"
        android:layout_marginTop="40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="30dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dateFromAdmin"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="от дата dd/mm/yyy"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/dateToAdmin"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="до дата dd/mm/yyy"
            android:textSize="18sp" />
    </LinearLayout>

    <Button
        android:id="@+id/CheckProdAdmin"
        android:layout_width="155dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="120dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:text="Справка" />

    <Button
        android:id="@+id/backBtToAdmin"
        android:layout_width="155dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="120dp"
        android:text="Назад" />
</LinearLayout>